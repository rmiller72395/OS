# Required
DISCORD_TOKEN=
OWNER_DISCORD_IDS=
RMFRAMEWORK_PERMIT_SECRET=

# Monitoring (required for rollout: alerts go here)
MONITORING_CHANNEL_ID=

# Optional ops
OPS_CHANNEL_ID=

# Optional providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional
ALLOWED_CHANNEL_IDS=
SOVEREIGN_ALERT_WEBHOOK=
SOVEREIGN_DISABLE_PAID_CALLS=0

# Safe mode: 1 = no paid model calls, no side-effect tools; diagnostics only
SAFE_MODE=0

# Simulation mode: 1 = alerts to data/simulated_alerts.jsonl (no Discord for alerts); use for preflight/harness
SIMULATION_MODE=0

# Persistent data root (default: cwd). Use for stable paths and multi-release.
# SOVEREIGN_DATA_DIR=C:\SovereignData

# Dashboard (default localhost:8765)
SOVEREIGN_DASHBOARD_HOST=127.0.0.1
SOVEREIGN_DASHBOARD_PORT=8765
